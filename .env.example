# =============================================================================
# Cosmic Password Manager API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=cosmic
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=cosmic
POSTGRES_PORT=5432

# Full connection URL (auto-generated in docker-compose, set manually for local dev)
DATABASE_URL=postgres://cosmic:change-me-in-production@localhost:5432/cosmic

# -----------------------------------------------------------------------------
# Cache (Valkey/Redis)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# CRITICAL: Generate a strong random secret for production!
# Example: openssl rand -base64 48
JWT_SECRET=development-only-change-this-in-production-min-32-chars

# Token expiration
JWT_EXPIRY_SECONDS=900
REFRESH_TOKEN_EXPIRY_DAYS=30

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Email (Mailtrap)
# -----------------------------------------------------------------------------
# Get your API token from https://mailtrap.io/
EMAIL__MAILTRAP_API_TOKEN=your-mailtrap-api-token
EMAIL__FROM_EMAIL=no-reply@example.com
EMAIL__FROM_NAME=App Name
EMAIL__REPLY_TO_EMAIL=support@example.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=info,cosmic_backend=debug

# -----------------------------------------------------------------------------
# Environment (Development/Production)
# -----------------------------------------------------------------------------
# Controls API documentation availability (docs only enabled in development)
ENVIRONMENT=development
